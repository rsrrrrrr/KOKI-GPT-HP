## 🔑 실제 API 키 설정

### 1️⃣ Anthropic Claude API 키 발급
1. https://console.anthropic.com/ 방문
2. 계정 생성 또는 로그인
3. API Keys 섹션에서 새 키 생성
4. $5 크레딧으로 테스트 가능

### 2️⃣ OpenAI API 키 발급  
1. https://platform.openai.com/ 방문
2. 계정 생성 또는 로그인
3. API keys 페이지에서 새 키 생성
4. $5 무료 크레딧으로 시작

### 3️⃣ 환경 변수 설정

**Windows:**
```cmd
set ANTHROPIC_API_KEY=sk-ant-your-actual-key-here
set OPENAI_API_KEY=sk-your-actual-openai-key-here
```

**macOS/Linux:**
```bash
export ANTHROPIC_API_KEY="sk-ant-your-actual-key-here"
export OPENAI_API_KEY="sk-your-actual-openai-key-here"
```

## 🧪 실제 API 테스트 예제

### examples/test-real-apis.js
```javascript
import fetch from 'node-fetch';

// 실제 Anthropic API 테스트
async function testClaudeAPI() {
    const apiKey = process.env.ANTHROPIC_API_KEY;
    if (!apiKey) {
        console.log('❌ ANTHROPIC_API_KEY 환경 변수가 설정되지 않았습니다.');
        return;
    }

    try {
        console.log('🤖 Claude API 테스트 중...');
        
        const response = await fetch('https://api.anthropic.com/v1/messages', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'x-api-key': apiKey,
                'anthropic-version': '2023-06-01'
            },
            body: JSON.stringify({
                model: 'claude-3-sonnet-20240229',
                max_tokens: 100,
                messages: [
                    { role: 'user', content: '안녕하세요! 간단한 인사말을 해주세요.' }
                ]
            })
        });

        if (response.ok) {
            const data = await response.json();
            console.log('✅ Claude 응답:', data.content[0].text);
        } else {
            console.log('❌ Claude API 오류:', response.status);
        }
    } catch (error) {
        console.log('❌ Claude API 연결 실패:', error.message);
    }
}

// 실제 OpenAI API 테스트
async function testOpenAIAPI() {
    const apiKey = process.env.OPENAI_API_KEY;
    if (!apiKey) {
        console.log('❌ OPENAI_API_KEY 환경 변수가 설정되지 않았습니다.');
        return;
    }

    try {
        console.log('🧠 OpenAI API 테스트 중...');
        
        const response = await fetch('https://api.openai.com/v1/chat/completions', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${apiKey}`
            },
            body: JSON.stringify({
                model: 'gpt-3.5-turbo',
                messages: [
                    { role: 'user', content: 'Hello! Please give me a simple greeting.' }
                ],
                max_tokens: 100
            })
        });

        if (response.ok) {
            const data = await response.json();
            console.log('✅ OpenAI 응답:', data.choices[0].message.content);
        } else {
            console.log('❌ OpenAI API 오류:', response.status);
        }
    } catch (error) {
        console.log('❌ OpenAI API 연결 실패:', error.message);
    }
}

// 메인 실행
async function main() {
    console.log('🚀 실제 AI API 테스트 시작\n');
    
    await testClaudeAPI();
    console.log('');
    await testOpenAIAPI();
    
    console.log('\n✨ 테스트 완료!');
}

main();
```

