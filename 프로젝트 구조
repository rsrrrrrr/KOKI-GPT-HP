## 🎮 예제 파일들

### examples/basic-usage.js

```javascript
const { KokiAIClient } = require('koki-ai-hub-sdk');

async function main() {
  console.log('🚀 Koki AI Hub SDK 기본 사용 예제');
  
  const client = new KokiAIClient({
    anthropicKey: process.env.ANTHROPIC_API_KEY,
    openaiKey: process.env.OPENAI_API_KEY
  });

  try {
    // Claude AI 테스트
    console.log('\n1️⃣ Claude AI 테스트...');
    const claudeResponse = await client.claude("안녕하세요! 간단한 자기소개를 해주세요.");
    console.log('Claude 응답:', claudeResponse.content?.[0]?.text);

    // OpenAI 테스트
    console.log('\n2️⃣ OpenAI 테스트...');
    const openaiResponse = await client.openai("Hello! Please introduce yourself briefly.");
    console.log('OpenAI 응답:', openaiResponse.choices?.[0]?.message?.content);

    // 헬스 체크
    console.log('\n3️⃣ 서비스 상태 확인...');
    const health = await client.getHealth();
    console.log('서비스 상태:', health.status);

    // 사용량 통계
    console.log('\n4️⃣ 사용량 통계...');
    const usage = await client.getUsageStats();
    console.log('오늘 사용량:', usage.today);

  } catch (error) {
    console.error('❌ 오류 발생:', error.message);
    if (error.toJSON) {
      console.error('상세 정보:', error.toJSON());
    }
  }
}

if (require.main === module) {
  main();
}
```

### examples/streaming.js

```javascript
const { KokiAIClient } = require('koki-ai-hub-sdk');

async function streamingExample() {
  console.log('🌊 스트리밍 응답 예제');
  
  const client = new KokiAIClient({
    anthropicKey: process.env.ANTHROPIC_API_KEY
  });

  try {
    console.log('\n📝 긴 이야기를 요청합니다...\n');
    
    const stream = await client.claudeStream(
      "흥미진진한 SF 단편소설을 써주세요. 500단어 정도로."
    );

    let fullText = '';
    for await (const chunk of stream) {
      if (chunk.delta?.text) {
        process.stdout.write(chunk.delta.text);
        fullText += chunk.delta.text;
      }
    }

    console.log('\n\n✅ 스트리밍 완료!');
    console.log(`📊 총 ${fullText.length}자 받았습니다.`);

  } catch (error) {
    console.error('❌ 스트리밍 오류:', error.message);
  }
}

if (require.main === module) {
  streamingExample();
}
```

### examples/websocket-demo.js

```javascript
const { KokiAIClient } = require('koki-ai-hub-sdk');

async function websocketDemo() {
  console.log('🔌 WebSocket 연결 데모');
  
  const client = new KokiAIClient();

  try {
    const ws = await client.connectWebSocket();
    console.log('✅ WebSocket 연결 성공!');

    // 이벤트 핸들러 설정
    ws.on('message', (data) => {
      console.log('📨 메시지 수신:', data);
    });

    ws.on('error', (error) => {
      console.error('❌ WebSocket 오류:', error);
    });

    ws.on('disconnected', () => {
      console.log('🔌 연결 해제됨');
    });

    // 테스트 메시지 전송
    console.log('\n💬 테스트 메시지 전송...');
    ws.sendChatMessage('안녕하세요! WebSocket 테스트입니다.');

    // 5초 후 연결 해제
    setTimeout(() => {
      console.log('\n👋 연결을 해제합니다...');
      client.disconnect();
    }, 5000);

  } catch (error) {
    console.error('❌ WebSocket 연결 실패:', error.message);
  }
}

if (require.main === module) {
  websocketDemo();
}
```

