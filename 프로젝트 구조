## 🎯 TypeScript 정의 파일 (src/types.d.ts)

```typescript
declare module 'koki-ai-hub-sdk' {
  export interface KokiAIClientOptions {
    baseURL?: string;
    anthropicKey?: string;
    openaiKey?: string;
    headers?: Record<string, string>;
  }

  export interface ChatMessage {
    role: 'user' | 'assistant' | 'system';
    content: string;
  }

  export interface ClaudeOptions {
    maxTokens?: number;
    temperature?: number;
    system?: string;
  }

  export interface OpenAIOptions {
    model?: string;
    maxTokens?: number;
    temperature?: number;
    topP?: number;
    frequencyPenalty?: number;
    presencePenalty?: number;
  }

  export interface WebSocketOptions {
    url?: string;
    maxReconnectAttempts?: number;
    reconnectDelay?: number;
  }

  export class KokiAIClient {
    constructor(options?: KokiAIClientOptions);
    
    claude(messages: string | ChatMessage[], options?: ClaudeOptions): Promise<any>;
    claudeStream(messages: string | ChatMessage[], options?: ClaudeOptions): Promise<AsyncIterable<any>>;
    openai(messages: string | ChatMessage[], options?: OpenAIOptions): Promise<any>;
    
    connectWebSocket(options?: WebSocketOptions): Promise<KokiWebSocket>;
    
    getCacheStats(): Promise<any>;
    clearCache(userSession?: string): Promise<any>;
    getHealth(): Promise<any>;
    getUsageStats(): Promise<any>;
    getMetrics(): Promise<any>;
    
    setAPIKey(service: string, key: string): void;
    getRateLimitStatus(service: string): any;
    disconnect(): void;
  }

  export class KokiWebSocket {
    constructor(url: string, options?: WebSocketOptions);
    
    connect(): Promise<void>;
    send(data: any): void;
    sendChatMessage(content: string): void;
    on(event: string, handler: (...args: any[]) => void): void;
    off(event: string, handler: (...args: any[]) => void): void;
    disconnect(): void;
    
    readonly isConnected: boolean;
  }

  export class KokiAPIError extends Error {
    status: number;
    type: string;
    code: string;
    details: any;
    requestId: string | null;
    timestamp: string;
    
    constructor(status: number, type: string, code: string, message: string, details?: any, requestId?: string);
    toJSON(): any;
  }

  export interface UseKokiAIOptions extends KokiAIClientOptions {}

  export interface UseKokiAIReturn {
    loading: boolean;
    error: KokiAPIError | null;
    responses: any[];
    sendMessage: (message: string, service?: string, options?: any) => Promise<any>;
    clearHistory: () => void;
    client: KokiAIClient;
  }

  export function useKokiAI(options?: UseKokiAIOptions): UseKokiAIReturn;
  
  export function delay(ms: number): Promise<void>;
  export function retryWithBackoff<T>(fn: () => Promise<T>, maxRetries?: number, baseDelay?: number): Promise<T>;
  
  export const CONFIG: {
    PROD_BASE_URL: string;
    LOCAL_BASE_URL: string;
    WS_URL: string;
    API_VERSION: string;
    USER_AGENT: string;
    RATE_LIMITS: any;
  };
}
```

