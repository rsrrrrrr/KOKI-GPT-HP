# Koki AI Hub 환경 설정 파일
# .env.example을 .env로 복사하고 실제 값으로 수정하세요

# ===========================================
# 🚀 기본 서버 설정
# ===========================================

# 환경 (development, staging, production)
NODE_ENV=development

# 서버 포트
PORT=3001

# 서버 호스트
HOST=0.0.0.0

# 베이스 URL (프로덕션에서 사용)
BASE_URL=https://koki-ai.com

# ===========================================
# 🔐 API 키 설정
# ===========================================

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
ANTHROPIC_API_URL=https://api.anthropic.com/v1

# OpenAI GPT API (선택사항)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_API_URL=https://api.openai.com/v1

# Google Cloud API (음성 인식용, 선택사항)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-cloud-key.json
GOOGLE_PROJECT_ID=your-google-project-id

# ===========================================
# 🗄️ 데이터베이스 설정
# ===========================================

# Redis 캐시
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_URL=redis://localhost:6379

# PostgreSQL (사용자 데이터용, 선택사항)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=koki_ai_hub
POSTGRES_USER=koki_user
POSTGRES_PASSWORD=your-postgres-password
DATABASE_URL=postgresql://koki_user:your-postgres-password@localhost:5432/koki_ai_hub

# MongoDB (로그용, 선택사항)
MONGODB_URI=mongodb://localhost:27017/koki_logs

# ===========================================
# 🔒 보안 설정
# ===========================================

# JWT 시크릿 키
JWT_SECRET=your-very-secure-jwt-secret-key-here-min-32-chars
JWT_EXPIRES_IN=7d

# 세션 시크릿
SESSION_SECRET=your-session-secret-key-here

# 암호화 키 (AES-256)
ENCRYPTION_KEY=your-32-character-encryption-key-here

# CORS 허용 도메인
CORS_ORIGIN=*
# 프로덕션에서는 구체적인 도메인 지정
# CORS_ORIGIN=https://koki-ai.com,https://app.koki-ai.com

# 신뢰할 수 있는 프록시
TRUSTED_PROXIES=127.0.0.1,::1

# ===========================================
# 📊 모니터링 및 로깅
# ===========================================

# 로그 레벨 (error, warn, info, verbose, debug, silly)
LOG_LEVEL=info

# 로그 파일 경로
LOG_FILE=./logs/koki-api.log

# Sentry DSN (에러 트래킹)
SENTRY_DSN=your-sentry-dsn-here

# New Relic 라이선스 키
NEW_RELIC_LICENSE_KEY=your-newrelic-license-key

# Prometheus 메트릭 활성화
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ===========================================
# 🚀 성능 및 제한 설정
# ===========================================

# 요청 제한 (분당)
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Claude API 요청 제한
CLAUDE_RATE_LIMIT=50
CLAUDE_RATE_WINDOW_MS=60000

# 파일 업로드 제한 (MB)
MAX_FILE_SIZE=10

# 요청 타임아웃 (초)
REQUEST_TIMEOUT=30

# 연결 풀 크기
CONNECTION_POOL_SIZE=10

# ===========================================
# 🔧 기능 플래그
# ===========================================

# 기능 활성화/비활성화
FEATURE_DUAL_AI=true
FEATURE_VIDEO_CHAT=true
FEATURE_VOICE_RECOGNITION=true
FEATURE_FILE_UPLOAD=true
FEATURE_ANALYTICS=true

# 실험적 기능
EXPERIMENTAL_STREAMING=false
EXPERIMENTAL_VOICE_CLONING=false

# ===========================================
# 📧 이메일 설정 (알림용)
# ===========================================

# SMTP 설정
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# 알림 이메일
ADMIN_EMAIL=admin@koki-ai.com
SUPPORT_EMAIL=support@koki-ai.com

# ===========================================
# ☁️ 클라우드 서비스
# ===========================================

# AWS S3 (파일 저장용)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=koki-ai-hub-files

# Google Cloud Storage
GCS_BUCKET_NAME=koki-ai-hub-storage
GCS_PROJECT_ID=your-gcs-project-id

# ===========================================
# 🔍 검색 엔진
# ===========================================

# Elasticsearch (검색 기능용)
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=koki_search

# Algolia (대안 검색 서비스)
ALGOLIA_APP_ID=your-algolia-app-id
ALGOLIA_API_KEY=your-algolia-api-key
ALGOLIA_INDEX_NAME=koki_search

# ===========================================
# 📱 푸시 알림
# ===========================================

# Firebase Cloud Messaging
FCM_SERVER_KEY=your-fcm-server-key
FCM_PROJECT_ID=your-firebase-project-id

# Apple Push Notification
APNS_KEY_ID=your-apns-key-id
APNS_TEAM_ID=your-apple-team-id
APNS_BUNDLE_ID=com.koki.ai.hub

# ===========================================
# 🎨 UI/UX 설정
# ===========================================

# 기본 테마
DEFAULT_THEME=light
ENABLE_DARK_MODE=true

# 언어 설정
DEFAULT_LANGUAGE=ko
SUPPORTED_LANGUAGES=ko,en,ja,zh

# 피드백 수집
FEEDBACK_ENABLED=true
ANALYTICS_TRACKING_ID=your-google-analytics-id

# ===========================================
# 🧪 테스트 및 개발
# ===========================================

# 테스트 모드
TEST_MODE=false

# 디버그 모드
DEBUG_MODE=false

# 모의 API 사용 (개발용)
MOCK_API_ENABLED=false

# 개발자 도구 활성화
DEV_TOOLS_ENABLED=true

# ===========================================
# 🔄 백업 및 복구
# ===========================================

# 자동 백업 활성화
AUTO_BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
BACKUP_RETENTION_DAYS=30

# 백업 저장소
BACKUP_STORAGE_TYPE=s3
BACKUP_S3_BUCKET=koki-ai-hub-backups

# ===========================================
# 📈 분석 및 통계
# ===========================================

# 사용량 분석
USAGE_ANALYTICS_ENABLED=true
ANONYMOUS_ANALYTICS=true

# 성능 메트릭 수집
PERFORMANCE_MONITORING=true

# A/B 테스트
AB_TESTING_ENABLED=false

# ===========================================
# 💳 결제 및 구독 (향후 기능)
# ===========================================

# Stripe
STRIPE_PUBLIC_KEY=pk_test_your-stripe-public-key
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# ===========================================
# 🌐 CDN 및 정적 파일
# ===========================================

# CDN URL
CDN_URL=https://cdn.koki-ai.com

# 정적 파일 경로
STATIC_FILES_PATH=./public

# 이미지 최적화
IMAGE_OPTIMIZATION_ENABLED=true
IMAGE_QUALITY=80

# ===========================================
# 🏥 헬스체크 설정
# ===========================================

# 헬스체크 간격 (초)
HEALTH_CHECK_INTERVAL=30

# 타임아웃 (초)
HEALTH_CHECK_TIMEOUT=5

# 재시도 횟수
HEALTH_CHECK_RETRIES=3

# ===========================================
# 🔐 SSL/TLS 설정
# ===========================================

# SSL 인증서 경로
SSL_CERT_PATH=./ssl/cert.pem
SSL_KEY_PATH=./ssl/key.pem

# HTTPS 강제 사용
FORCE_HTTPS=true

# HSTS 활성화
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000

# ===========================================
# 📝 추가 설정
# ===========================================

# 타임존
TZ=Asia/Seoul

# 기본 인코딩
DEFAULT_ENCODING=utf8

# 최대 동시 연결 수
MAX_CONNECTIONS=1000

# Keep-Alive 타임아웃
KEEP_ALIVE_TIMEOUT=5000

# ===========================================
# 🚨 경고 및 주의사항
# ===========================================

# ⚠️ 중요: 프로덕션 환경에서는 다음 사항을 확인하세요:
# 1. 모든 API 키를 실제 값으로 변경
# 2. 강력한 비밀번호 사용
# 3. CORS_ORIGIN을 구체적인 도메인으로 제한
# 4. DEBUG_MODE와 TEST_MODE를 false로 설정
# 5. 적절한 로그 레벨 설정 (error 또는 warn)
# 6. SSL/HTTPS 활성화
# 7. 정기적인 보안 업데이트

# 💡 팁: 이 파일을 .gitignore에 추가하여 버전 관리에서 제외하세요
