/**
 * Koki AI Hub API 프록시 서버
 * Claude API 및 기타 외부 API 호출을 중계하고 캐싱 처리
 */

const express = require('express');
const cors = require('cors');
const helmet = require('helmet');
const rateLimit = require('express-rate-limit');
const Redis = require('redis');
const { createProxyMiddleware } = require('http-proxy-middleware');
const WebSocket = require('ws');
const http = require('http');
const https = require('https');
const crypto = require('crypto');

// 환경 설정
const config = {
    port: process.env.PORT || 3001,
    env: process.env.NODE_ENV || 'development',
    redis: {
        host: process.env.REDIS_HOST || 'redis',
        port: process.env.REDIS_PORT || 6379,
        password: process.env.REDIS_PASSWORD
    },
    anthropic: {
        apiKey: process.env.ANTHROPIC_API_KEY,
        baseUrl: 'https://api.anthropic.com/v1'
    },
    openai: {
        apiKey: process.env.OPENAI_API_KEY,
        baseUrl: 'https://api.openai.com/v1'
    },
    cors: {
        origin: process.env.CORS_ORIGIN || '*',
        credentials: true
    }
};

class KokiAPIProxy {
    constructor() {
        this.app = express();
        this.server = http.createServer(this.app);
        this.redis = null;
        this.wss = null;
        
        this.setupRedis();
        this.setupMiddleware();
        this.setupRoutes();
        this.setupWebSocket();
        this.setupErrorHandling();
    }
    
    async setupRedis() {
        try {
            this.redis = Redis.createClient({
                socket: {
                    host: config.redis.host,
                    port: config.redis.port
                },
                password: config.redis.password
            });
            
            await this.redis.connect();
            console.log('✅ Redis 연결 성공');
            
        } catch (error) {
            console.warn('⚠️ Redis 연결 실패, 캐싱 비활성화:', error.message);
        }
    }
    
    setupMiddleware() {
        // 보안 미들웨어
        this.app.use(helmet({
            contentSecurityPolicy: {
                directives: {
                    defaultSrc: ["'self'"],
                    scriptSrc: ["'self'", "'unsafe-inline'", "'unsafe-eval'"],
                    styleSrc: ["'self'", "'unsafe-inline'"],
                    imgSrc: ["'self'", "data:", "blob:"],
                    connectSrc: ["'self'", "wss:", "ws:"],
                    fontSrc: ["'self'"],
                    objectSrc: ["'none'"],
                    mediaSrc: ["'self'"],
                    frameSrc: ["'none'"]
                }
            }
        }));
        
        // CORS 설정
        this.app.use(cors(config.cors));
        
        // 레이트 제한
        const apiLimiter = rateLimit({
            windowMs: 15 * 60 * 1000, // 15분
            max: 100, // 요청 수 제한
            message: {
                error: 'Too many requests, please try again later'
            },
            standardHeaders: true,
            legacyHeaders: false
        });
        
        const claudeLimiter = rateLimit({
            windowMs: 60 * 1000, // 1분
            max: 50, // Claude API 제한에 맞춤
            message: {
                error: 'Claude API rate limit exceeded'
            }
        });
        
        this.app.use('/api/', apiLimiter);
        this.app.use('/api/claude/', claudeLimiter);
        
        // JSON 파싱
        this.app.use(express.json({ limit: '10mb' }));
        
        // 요청 로깅
        this.app.use((req, res, next) => {
            const start = Date.now();
            res.on('finish', () => {
                const duration = Date.now() - start;
                console.log(`${req.method} ${req.path} - ${res.statusCode} (${duration}ms)`);
            });
            next();
        });
    }
    
    setupRoutes() {
        // 건강 상태 확인
        this.app.get('/health', (req, res) => {
            res.json({
                status: 'healthy',
                timestamp: new Date().toISOString(),
                uptime: process.uptime(),
                redis: this.redis?.isReady || false
            });
        });
        
        // Claude API 프록시
        this.app.post('/api/claude/messages', this.handleClaudeRequest.bind(this));
        this.app.post('/api/claude/stream', this.handleClaudeStream.bind(this));
        
        // OpenAI API 프록시
        this.app.post('/api/openai/chat/completions', this.handleOpenAIRequest.bind(this));
        
        // 캐시 관리
        this.app.delete('/api/cache/:key', this.handleCacheDelete.bind(this));
        this.app.get('/api/cache/stats', this.handleCacheStats.bind(this));
        
        // 사용량 통계
        this.app.get('/api/stats/usage', this.handleUsageStats.bind(this));
        
        // 일반적인 프록시 설정 (기타 API)
        this.app.use('/proxy', createProxyMiddleware({
            target: 'https://api.example.com',
            changeOrigin: true,
            pathRewrite: {
                '^/proxy': ''
            },
            onError: (err, req, res) => {
                console.error('프록시 오류:', err);
                res.status(502).json({ error: 'Proxy error' });
            }
        }));
    }
    
    async handleClaudeRequest(req, res) {
        try {
            const { messages, ...options } = req.body;
            
            // 요청 검증
            if (!messages || !Array.isArray(messages)) {
                return res.status(400).json({
                    error: 'Invalid request: messages array required'
                });
            }
            
            // 캐시 키 생성
            const cacheKey = this.generateCacheKey('claude', { messages, options });
            
            // 캐시 확인
            const cached = await this.getFromCache(cacheKey);
            if (cached) {
                console.log('📦 캐시에서 응답 반환');
                return res.json(cached);
            }
            
            // Claude API 호출
            const response = await this.callClaudeAPI(messages, options);
            
            // 성공적인 응답을 캐시에 저장 (1시간)
            await this.setCache(cacheKey, response, 3600);
            
            // 사용량 기록
            await this.recordUsage('claude', req.ip);
            
            res.json(response);
            
        } catch (error) {
            console.error('Claude API 오류:', error);
            this.handleAPIError(res, error);
        }
    }
    
    async handleClaudeStream(req, res) {
        try {
            const { messages, ...options } = req.body;
            
            res.writeHead(200, {
                'Content-Type': 'text/event-stream',
                'Cache-Control': 'no-cache',
                'Connection': 'keep-alive',
                'Access-Control-Allow-Origin': '*'
            });
            
            await this.streamClaudeAPI(messages, options, (chunk) => {
                res.write(`data: ${JSON.stringify(chunk)}\n\n`);
            });
            
            res.write('data: [DONE]\n\n');
            res.end();
            
            await this.recordUsage('claude_stream', req.ip);
            
        } catch (error) {
            console.error('Claude 스트림 오류:', error);
            res.write(`data: ${JSON.stringify({ error: error.message })}\n\n`);
            res.end();
        }
    }
    
    async handleOpenAIRequest(req, res) {
        try {
            const { messages, ...options } = req.body;
            
            if (!config.openai.apiKey) {
                return res.status(503).json({
                    error: 'OpenAI API key not configured'
                });
            }
            
            const cacheKey = this.generateCacheKey('openai', { messages, options });
            const cached = await this.getFromCache(cacheKey);
            
            if (cached) {
                return res.json(cached);
            }
            
            const response = await this.callOpenAIAPI(messages, options);
            await this.setCache(cacheKey, response, 3600);
            await this.recordUsage('openai', req.ip);
            
            res.json(response);
            
        } catch (error) {
            console.error('OpenAI API 오류:', error);
            this.handleAPIError(res, error);
        }
    }
    
    async callClaudeAPI(messages, options = {}) {
        const requestData = {
            model: options.model || 'claude-3-sonnet-20240229',
            max_tokens: options.max_tokens || 4096,
            messages: messages
        };
        
        if (options.system) {
            requestData.system = options.system;
        }
        
        const response = await fetch(`${config.anthropic.baseUrl}/messages`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'x-api-key': config.anthropic.apiKey,
                'anthropic-version': '2023-06-01'
            },
            body: JSON.stringify(requestData)
        });
        
        if (!response.ok) {
            const error = await response.json().catch(() => ({}));
            throw new Error(error.error?.message || `HTTP ${response.status}`);
        }
        
        return await response.json();
    }
    
    async streamClaudeAPI(messages, options, onChunk) {
        const requestData = {
            model: options.model || 'claude-3-sonnet-20240229',
            max_tokens: options.max_tokens || 4096,
            messages: messages,
            stream: true
        };
        
        const response = await fetch(`${config.anthropic.baseUrl}/messages`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'x-api-key': config.anthropic.apiKey,
                'anthropic-version': '2023-06-01'
            },
            body: JSON.stringify(requestData)
        });
        
        if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
        }
        
        const reader = response.body.getReader();
        const decoder = new TextDecoder();
        
        try {
            while (true) {
                const { done, value } = await reader.read();
                if (done) break;
                
                const chunk = decoder.decode(value);
                const lines = chunk.split('\n');
                
                for (const line of lines) {
                    if (line.startsWith('data: ')) {
                        const data = line.slice(6);
                        if (data === '[DONE]') return;
                        
                        try {
                            const parsed = JSON.parse(data);
                            if (parsed.type === 'content_block_delta') {
                                onChunk({
                                    type: 'content',
                                    text: parsed.delta?.text || ''
                                });
                            }
                        } catch (e) {
                            // JSON 파싱 오류 무시
                        }
                    }
                }
            }
        } finally {
            reader.releaseLock();
        }
    }
    
    async callOpenAIAPI(messages, options = {}) {
        const requestData = {
            model: options.model || 'gpt-4',
            messages: messages,
            max_tokens: options.max_tokens || 4096,
            temperature: options.temperature || 0.7
        };
        
        const response = await fetch(`${config.openai.baseUrl}/chat/completions`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${config.openai.apiKey}`
            },
            body: JSON.stringify(requestData)
        });
        
        if (!response.ok) {
            const error = await response.json().catch(() => ({}));
            throw new Error(error.error?.message || `HTTP ${response.status}`);
        }
        
        return await response.json();
    }
    
    generateCacheKey(service, data) {
        const hash = crypto.createHash('sha256');
        hash.update(JSON.stringify({ service, data }));
        return `cache:${service}:${hash.digest('hex')}`;
    }
    
    async getFromCache(key) {
        if (!this.redis?.isReady) return null;
        
        try {
            const cached = await this.redis.get(key);
            return cached ? JSON.parse(cached) : null;
        } catch (error) {
            console.warn('캐시 읽기 오류:', error);
            return null;
        }
    }
    
    async setCache(key, value, ttl = 3600) {
        if (!this.redis?.isReady) return;
        
        try {
            await this.redis.setEx(key, ttl, JSON.stringify(value));
        } catch (error) {
            console.warn('캐시 저장 오류:', error);
        }
    }
    
    async recordUsage(service, ip) {
        if (!this.redis?.isReady) return;
        
        try {
            const today = new Date().toISOString().split('T')[0];
            const usageKey = `usage:${service}:${today}`;
            const ipKey = `usage:ip:${ip}:${today}`;
            
            await Promise.all([
                this.redis.incr(usageKey),
                this.redis.incr(ipKey),
                this.redis.expire(usageKey, 86400 * 7), // 7일 보관
                this.redis.expire(ipKey, 86400 * 7)
            ]);
        } catch (error) {
            console.warn('사용량 기록 오류:', error);
        }
    }
    
    async handleCacheDelete(req, res) {
        try {
            const { key } = req.params;
            
            if (!this.redis?.isReady) {
                return res.status(503).json({ error: 'Redis not available' });
            }
            
            const deleted = await this.redis.del(key);
            res.json({ deleted: deleted > 0 });
            
        } catch (error) {
            res.status(500).json({ error: error.message });
        }
    }
    
    async handleCacheStats(req, res) {
        try {
            if (!this.redis?.isReady) {
                return res.status(503).json({ error: 'Redis not available' });
            }
            
            const info = await this.redis.info('memory');
            const stats = {};
            
            info.split('\r\n').forEach(line => {
                const [key, value] = line.split(':');
                if (key && value) {
                    stats[key] = value;
                }
            });
            
            res.json(stats);
            
        } catch (error) {
            res.status(500).json({ error: error.message });
        }
    }
    
    async handleUsageStats(req, res) {
        try {
            if (!this.redis?.isReady) {
                return res.json({ error: 'Redis not available' });
            }
            
            const today = new Date().toISOString().split('T')[0];
            const services = ['claude', 'openai', 'claude_stream'];
            
            const stats = {};
            
            for (const service of services) {
                const usageKey = `usage:${service}:${today}`;
                const count = await this.redis.get(usageKey);
                stats[service] = parseInt(count) || 0;
            }
            
            res.json(stats);
            
        } catch (error) {
            res.status(500).json({ error: error.message });
        }
    }
    
    handleAPIError(res, error) {
        let status = 500;
        let message = 'Internal server error';
        
        if (error.message.includes('401')) {
            status = 401;
            message = 'Invalid API key';
        } else if (error.message.includes('429')) {
            status = 429;
            message = 'Rate limit exceeded';
        } else if (error.message.includes('400')) {
            status = 400;
            message = 'Bad request';
        }
        
        res.status(status).json({
            error: message,
            details: config.env === 'development' ? error.message : undefined
        });
    }
    
    setupWebSocket() {
        this.wss = new WebSocket.Server({ 
            server: this.server,
            path: '/ws'
        });
        
        this.wss.on('connection', (ws, req) => {
            console.log('🔌 WebSocket 연결:', req.socket.remoteAddress);
            
            ws.on('message', async (message) => {
                try {
                    const data = JSON.parse(message);
                    
                    switch (data.type) {
                        case 'chat':
                            await this.handleWebSocketChat(ws, data);
                            break;
                        case 'ping':
                            ws.send(JSON.stringify({ type: 'pong' }));
                            break;
                        default:
                            ws.send(JSON.stringify({ 
                                type: 'error', 
                                message: 'Unknown message type' 
                            }));
                    }
                    
                } catch (error) {
                    ws.send(JSON.stringify({ 
                        type: 'error', 
                        message: error.message 
                    }));
                }
            });
            
            ws.on('close', () => {
                console.log('🔌 WebSocket 연결 종료');
            });
        });
    }
    
    async handleWebSocketChat(ws, data) {
        try {
            const response = await this.callClaudeAPI(data.messages, data.options);
            
            ws.send(JSON.stringify({
                type: 'chat_response',
                id: data.id,
                response: response
            }));
            
        } catch (error) {
            ws.send(JSON.stringify({
                type: 'chat_error',
                id: data.id,
                error: error.message
            }));
        }
    }
    
    setupErrorHandling() {
        this.app.use((err, req, res, next) => {
            console.error('애플리케이션 오류:', err);
            
            res.status(500).json({
                error: 'Internal server error',
                details: config.env === 'development' ? err.message : undefined
            });
        });
        
        process.on('unhandledRejection', (reason, promise) => {
            console.error('처리되지 않은 Promise 거부:', reason);
        });
        
        process.on('uncaughtException', (error) => {
            console.error('처리되지 않은 예외:', error);
            process.exit(1);
        });
        
        // Graceful shutdown
        process.on('SIGINT', () => this.gracefulShutdown('SIGINT'));
        process.on('SIGTERM', () => this.gracefulShutdown('SIGTERM'));
    }
    
    async gracefulShutdown(signal) {
        console.log(`\n${signal} 신호 수신, 서버 종료 중...`);
        
        this.server.close(() => {
            console.log('HTTP 서버 종료됨');
        });
        
        if (this.wss) {
            this.wss.close(() => {
                console.log('WebSocket 서버 종료됨');
            });
        }
        
        if (this.redis?.isReady) {
            await this.redis.quit();
            console.log('Redis 연결 종료됨');
        }
        
        process.exit(0);
    }
    
    start() {
        this.server.listen(config.port, () => {
            console.log('🚀 Koki API 프록시 서버 시작됨');
            console.log(`📍 포트: ${config.port}`);
            console.log(`🌍 환경: ${config.env}`);
            console.log(`📊 Redis: ${this.redis?.isReady ? '연결됨' : '연결 안됨'}`);
            
            if (config.env === 'development') {
                console.log('🔧 개발 모드 활성화');
                console.log(`📡 API 엔드포인트: http://localhost:${config.port}/api`);
                console.log(`🔌 WebSocket: ws://localhost:${config.port}/ws`);
            }
        });
    }
}

// 서버 시작
if (require.main === module) {
    const proxy = new KokiAPIProxy();
    proxy.start();
}

module.exports = KokiAPIProxy;
