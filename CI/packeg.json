{
  "name": "koki-ai-hub-api-proxy",
  "version": "2.0.0",
  "description": "API 프록시 서버 for Koki AI Hub - Claude & GPT-4 통합 플랫폼",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "security-check": "npm audit",
    "docker:build": "docker build -t koki-api-proxy .",
    "docker:run": "docker run -p 3001:3001 koki-api-proxy",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop koki-api-proxy",
    "pm2:restart": "pm2 restart koki-api-proxy",
    "pm2:logs": "pm2 logs koki-api-proxy",
    "benchmark": "node benchmark.js",
    "health-check": "node healthcheck.js"
  },
  "keywords": [
    "ai",
    "claude",
    "gpt-4",
    "api-proxy",
    "chatbot",
    "artificial-intelligence",
    "anthropic",
    "openai"
  ],
  "author": {
    "name": "Koki AI Team",
    "email": "dev@koki-ai.com",
    "url": "https://koki-ai.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/koki-ai/hub.git"
  },
  "bugs": {
    "url": "https://github.com/koki-ai/hub/issues"
  },
  "homepage": "https://koki-ai.com",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "redis": "^4.6.12",
    "http-proxy-middleware": "^2.0.6",
    "ws": "^8.16.0",
    "node-fetch": "^3.3.2",
    "dotenv": "^16.3.1",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "express-slow-down": "^1.6.0",
    "express-brute": "^1.0.1",
    "express-brute-redis": "^0.0.1",
    "node-cache": "^5.1.2",
    "ioredis": "^5.3.2",
    "async": "^3.2.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "eslint": "^8.56.0",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0",
    "cross-env": "^7.0.3",
    "artillery": "^2.0.3",
    "clinic": "^12.1.0",
    "0x": "^5.5.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "**/*.js",
      "!node_modules/**",
      "!coverage/**",
      "!jest.config.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "pre-push": "npm test"
    }
  },
  "config": {
    "port": 3001,
    "redis_url": "redis://localhost:6379",
    "cors_origin": "*",
    "log_level": "info"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8",
    "utf-8-validate": "^6.0.3"
  },
  "peerDependencies": {
    "pm2": "^5.3.0"
  },
  "overrides": {
    "semver": "^7.5.4"
  }
}
